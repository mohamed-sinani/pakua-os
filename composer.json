{
    "name": "pakuaos/app",
    "description": "CLI tool for finding and downloading operating systems — Find. Verify. Install.",
    "type": "library",
    "license": "MIT",
    "keywords": ["cli", "download", "operating-system", "iso", "linux", "windows", "macos"],
    "authors": [
        {
            "name": "Mohamed Sinani",
            "email": "dev@mohamedsinani.com",
            "homepage": "https://dev.mohamedsinani.com"
        }
    ],
    "homepage": "https://github.com/mohamed-sinani/pakuaos",
    "support": {
        "issues": "https://github.com/mohamed-sinani/pakuaos/issues",
        "source": "https://github.com/mohamed-sinani/pakuaos",
        "docs": "https://github.com/mohamed-sinani/pakuaos#readme"
    },
    "autoload": {
        "psr-4": {
            "PakuaOS\\": "src/"
        }
    },
    "bin": [
        "pakuaos"
    ],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "symfony/console": "^7.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
